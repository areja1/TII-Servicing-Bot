# ---------------------------------------------------------------------------
# TII Servicing Bot - Environment Variables
# Copy this file to ".env.local" and fill in real values. Never commit secrets.
# ---------------------------------------------------------------------------

# --- Anthropic (Claude Sonnet 4.6) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# Primary model id used by the chat API.
ANTHROPIC_MODEL=claude-sonnet-4-6
# Optional cheaper model for simple lookups (only used when routing is enabled).
ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5
# Optional: route simple, non-safety-critical lookups to the Haiku model.
# Leave OFF until Haiku has been validated against all 95 test scenarios
# (especially the prompt-injection set). The prompt cache is per-model, so
# enabling this trades some cache reuse for lower per-token cost.
ENABLE_HAIKU_ROUTING=false

# --- Privacy: CoB page-text redaction ---
# Pipe- or newline-separated strings stripped from the CoB page text at ingest
# (and again at read time) so the traveler's home address never reaches the
# model. Supply the address in normal human form; matching is case-insensitive
# and whitespace-insensitive. Leave unset to redact nothing. NEVER commit real
# PII — set this only in .env.local.
# COB_REDACT_STRINGS=123 Main Street Apt 4|Springfield, CA 90210

# --- Supabase (managed PostgreSQL knowledge base) ---
# Public project URL, e.g. https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Anonymous (public) key - safe for the browser, RLS-protected.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key - SERVER ONLY. Used by the ingestion script and API route.
# NEVER expose this to the client or commit it.
SUPABASE_SERVICE_ROLE_KEY=

# --- AviationStack (Flight Delay FNOL proof-of-concept) ---
# Free key from https://aviationstack.com . Free tier is HTTP-only and capped
# at ~100 requests/month. Used server-side by src/lib/flight/flight-status.ts
# to look up flight delays. NEVER commit a real key — set it only in .env.local.
AVIATIONSTACK_API_KEY=

# --- App configuration ---
# Max chat messages allowed per minute per client IP (in-memory rate limit).
RATE_LIMIT_PER_MIN=15
