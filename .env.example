# ---------------------------------------------------------------------------
# TII Servicing Bot - Environment Variables
# Copy this file to ".env.local" and fill in real values. Never commit secrets.
# ---------------------------------------------------------------------------

# --- Anthropic (Claude Sonnet 4.6) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# Model id used by the chat API and guardrails.
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Supabase (managed PostgreSQL knowledge base) ---
# Public project URL, e.g. https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Anonymous (public) key - safe for the browser, RLS-protected.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key - SERVER ONLY. Used by the ingestion script and API route.
# NEVER expose this to the client or commit it.
SUPABASE_SERVICE_ROLE_KEY=

# --- App configuration ---
# Number of passages to retrieve per query (Confirmation of Benefits + pinned
# Plan Document sub-limits are always added on top of these). 10 matches the
# tested, validated configuration.
RETRIEVAL_TOP_K=10
# Max chat messages allowed per minute per client IP (in-memory rate limit).
RATE_LIMIT_PER_MIN=15
