# ---------------------------------------------------------------------------
# Dependencies
# ---------------------------------------------------------------------------
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ---------------------------------------------------------------------------
# Next.js / build output
# ---------------------------------------------------------------------------
/.next/
/out/
/build
/dist
next-env.d.ts
*.tsbuildinfo

# ---------------------------------------------------------------------------
# Environment & secrets (NEVER commit real keys)
# ---------------------------------------------------------------------------
.env
.env*.local
.env.development
.env.production
.env.test
!.env.example

# ---------------------------------------------------------------------------
# Supabase local dev
# ---------------------------------------------------------------------------
/supabase/.branches
/supabase/.temp
/supabase/.env

# ---------------------------------------------------------------------------
# Logs & debug
# ---------------------------------------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs
*.log

# ---------------------------------------------------------------------------
# Testing / coverage
# ---------------------------------------------------------------------------
/coverage
/.nyc_output

# ---------------------------------------------------------------------------
# Vercel
# ---------------------------------------------------------------------------
.vercel

# ---------------------------------------------------------------------------
# Editor / OS / IDE
# ---------------------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea
.cursor/
.DS_Store
Thumbs.db
*.swp

# ---------------------------------------------------------------------------
# Local ingestion artifacts (parsed/chunked output kept out of git)
# ---------------------------------------------------------------------------
/scripts/ingest/output/
*.local.json

# ---------------------------------------------------------------------------
# Source PDFs (traveler PII — keep local; production reads from Supabase)
# Re-ingest after changes: npm run ingest
# ---------------------------------------------------------------------------
/docs/source-documents/*.pdf

# ---------------------------------------------------------------------------
# Generated test reports (re-run scripts in scripts/test/)
# ---------------------------------------------------------------------------
/scripts/test/results.md
/scripts/test/*-results.md

# ---------------------------------------------------------------------------
# Scratch / temporary files (debug output, scratch notes)
# ---------------------------------------------------------------------------
*.tmp
*.temp
*.bak
*.orig
scratch/
tmp/
# Throwaway scripts (underscore-prefixed) — may touch keys/PII; never commit.
scripts/**/_*.ts
